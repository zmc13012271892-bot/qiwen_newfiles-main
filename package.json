{
  "name": "qiwen",
  "version": "1.0.0",
  "description": "启文软件 - 本地优先的知识管理与写作平台 · 启于思，行于文",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cross-env BROWSER=none react-scripts start",
    "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "cross-env CI=false react-scripts build",
    "build:electron": "electron-builder build --config electron-builder.json",
    "build:win": "electron-builder build --win --config electron-builder.json",
    "build:mac": "electron-builder build --mac --config electron-builder.json",
    "build:linux": "electron-builder build --linux --config electron-builder.json",
    "test": "react-scripts test --watchAll=false",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.2.4",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.26.3",
    "@electron/remote": "^2.1.2",
    "@reduxjs/toolkit": "^2.2.5",
    "date-fns": "^3.6.0",
    "electron-log": "^5.1.5",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1",
    "framer-motion": "^6.5.0",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.23.1",
    "react-scripts": "5.0.1",
    "redux-persist": "^6.0.0",
    "sql.js": "^1.14.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "@tiptap/react": "^2.4.0",
    "@tiptap/pm": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "@tiptap/extension-placeholder": "^2.4.0",
    "@tiptap/extension-typography": "^2.4.0",
    "@tiptap/extension-link": "^2.4.0",
    "@tiptap/extension-image": "^2.4.0",
    "@tiptap/extension-table": "^2.4.0",
    "@tiptap/extension-table-row": "^2.4.0",
    "@tiptap/extension-table-cell": "^2.4.0",
    "@tiptap/extension-table-header": "^2.4.0",
    "@tiptap/extension-task-list": "^2.4.0",
    "@tiptap/extension-task-item": "^2.4.0",
    "@tiptap/extension-highlight": "^2.4.0",
    "@tiptap/extension-underline": "^2.4.0",
    "@tiptap/extension-text-align": "^2.4.0",
    "@tiptap/extension-color": "^2.4.0",
    "@tiptap/extension-text-style": "^2.4.0",
    "@tiptap/extension-character-count": "^2.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "typescript": "^4.9.5",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  }
}